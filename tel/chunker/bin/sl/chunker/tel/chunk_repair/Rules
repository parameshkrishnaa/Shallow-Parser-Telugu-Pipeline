R2: NP~1(({$a%NST<root="maXya",lcat="$c",gend="$g",num="$n",pers="$p",cm="0">})) NP~2(({%NN})) => NP~2((+{$a%NST<root="maXya",lcat="$c",gend="$g",num="$n",pers="$p",cm="0">}{%NN}))
